# ==============================================
# IPL PREDICTION BOT - Environment Configuration
# ==============================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# ----------------------------------------------
# TELEGRAM BOT
# ----------------------------------------------
# Get your token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ----------------------------------------------
# MONGODB DATABASE
# ----------------------------------------------
# Format: mongodb+srv://<username>:<password>@cluster.mongodb.net/<dbname>
MONGODB_URI=mongodb+srv://username:password@cluster0.mongodb.net/ipl-prediction-bot?retryWrites=true&w=majority

# ----------------------------------------------
# RAZORPAY PAYMENT GATEWAY
# ----------------------------------------------
# Get keys from https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# ----------------------------------------------
# ADMIN CONFIGURATION
# ----------------------------------------------
# Your Telegram user ID (get from @userinfobot)
ADMIN_USER_ID=123456789

# ----------------------------------------------
# SERVER SETTINGS
# ----------------------------------------------
PORT=8000
NODE_ENV=development

# ----------------------------------------------
# PAYMENT SETTINGS
# ----------------------------------------------
# Amount in paise (100 paise = ₹1)
# Default: 4900 = ₹49
PAYMENT_AMOUNT=4900
PAYMENT_CURRENCY=INR

# ----------------------------------------------
# WEBHOOK (for production deployment)
# ----------------------------------------------
# Your server's public URL for Telegram webhook
# Example: https://your-domain.com
WEBHOOK_URL=https://your-domain.com
